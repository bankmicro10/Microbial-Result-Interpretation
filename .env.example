# คัดลอกเป็น .env สำหรับ dev (อย่า commit .env จริง) — บน Vercel ตั้งใน Project Settings → Environment Variables
SECRET_KEY=change-me-to-a-long-random-string
# Postgres (Neon/Vercel Postgres). เว้นว่าง = ใช้ SQLite ในเครื่อง (dev)
DATABASE_URL=
# Google OAuth (สร้างใน Google Cloud Console). เว้นว่าง = ซ่อนปุ่ม Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# user เริ่มต้น (สร้างอัตโนมัติตอน start ถ้ายังไม่มี). ต้องตั้ง SEED_PASSWORD ไม่งั้นข้าม
SEED_USERNAME=cpffoodlab
SEED_PASSWORD=
SEED_EMAIL=
